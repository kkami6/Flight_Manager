@model IEnumerable<MVC.ViewModels.AdminFlightViewModel>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Flight Management (Admin)</h2>
        <a asp-action="Create" class="btn btn-success">Add New Flight</a>
    </div>

    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Route</th>
                <th>Departure</th>
                <th>Duration</th>
                <th>Passengers</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var flight in Model)
            {
                var collapseId = "passengers-" + flight.FlightId;
                <tr>
                    <td><strong>@flight.DepartureLocation ➔ @flight.LandingLocation</strong></td>
                    <td>@flight.DepartureTime.ToString("g")</td>
                    <td><span class="badge bg-info text-dark">@flight.Duration</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                            View Passengers (@flight.Passengers.Count)
                        </button>
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@flight.FlightId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@flight.FlightId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>

                <tr class="collapse" id="@collapseId">
                    <td colspan="5" class="bg-light">
                        <div class="p-3">
                            <h6>Passenger Manifest:</h6>
                            @if (!flight.Passengers.Any())
                            {
                                <p class="text-muted small">No passengers booked yet.</p>
                            }
                            else
                            {
                                <table class="table table-sm table-striped">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Type</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var p in flight.Passengers)
                                        {
                                            <tr>
                                                <td>@p.FirstName @p.LastName</td>
                                                <td>@p.ContactEmail</td>
                                                <td>@p.FlightType</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>