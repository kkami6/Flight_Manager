@model BusinessLayer.Models.Flight

@{
    ViewData["Title"] = "Create New Flight";
}

<h2>Create New Flight</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label asp-for="DepartureLocation" class="control-label">Departure Location</label>
                <input asp-for="DepartureLocation" class="form-control" />
                <span asp-validation-for="DepartureLocation" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="LandingLocation" class="control-label">Landing Location</label>
                <input asp-for="LandingLocation" class="form-control" />
                <span asp-validation-for="LandingLocation" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DepartureTime" class="control-label">Departure Time</label>
                <input asp-for="DepartureTime" type="datetime-local" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="LandingTime" class="control-label">Landing Time</label>
                <input asp-for="LandingTime" type="datetime-local" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="PlaneType" class="control-label">Plane Type</label>
                <input asp-for="PlaneType" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="PlaneId" class="control-label"></label>
                <input asp-for="PlaneId" class="form-control" placeholder="e.g. B737-800" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="PilotName" class="control-label">Pilot Name</label>
                <input asp-for="PilotName" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="PassengerCapacity" class="control-label">Passenger Capacity</label>
                <input asp-for="PassengerCapacity" type="number" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="BusinessClassCapacity" class="control-label">Business Class Capacity</label>
                <input asp-for="BusinessClassCapacity" type="number" class="form-control" />
            </div>

            <div class="form-group">
                <input type="submit" value="Save Flight" class="btn btn-primary" />
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>