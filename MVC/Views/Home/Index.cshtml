
@using MVC.ViewModels
@model IEnumerable<BulkReservationSummaryViewModel>

@{
    ViewData["Title"] = "Home";
}

<div class="container mt-4">
    <h2>All Reservations</h2>

    <form method="get" asp-action="Index" class="mb-4">
        <div class="input-group w-50 shadow-sm">
            <input type="text" name="searchEmail" value="@ViewBag.SearchEmail"
                   class="form-control" placeholder="Filter by contact email..." />
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i> Search
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchEmail))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info shadow-sm">
            <i class="bi bi-info-circle me-2"></i> No reservations found matching your criteria.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Contact Email</th>
                        <th>Flight Route</th>
                        <th>Passengers</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        // Generate a safe HTML ID for the collapse section
                        var collapseId = "details_" + item.FlightId + "_" + item.ContactEmail.Replace("@", "_").Replace(".", "_");

                        <tr>
                            <td class="fw-bold">@item.ContactEmail</td>
                            <td>
                                <span class="text-muted">From:</span> @item.Departure <br />
                                <span class="text-muted">To:</span> @item.Landing
                            </td>
                            <td>
                                <span class="badge bg-primary rounded-pill">@item.PassengerCount People</span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                    Show/Hide Details
                                </button>
                            </td>
                        </tr>

                        <tr class="collapse" id="@collapseId">
                            <td colspan="4" class="bg-light p-0">
                                <div class="p-4 border-start border-primary border-4">
                                    <h6 class="mb-3 text-primary">Registered Passengers:</h6>
                                    <div class="row g-3">
                                        @foreach (var person in item.GroupMembers)
                                        {
                                            <div class="col-md-4">
                                                <div class="card h-100 shadow-sm border-0">
                                                    <div class="card-body">
                                                        <h6 class="card-title mb-1">@person.FirstName @person.LastName</h6>
                                                        <p class="card-text small text-muted mb-0">
                                                            <strong>ID:</strong> @person.PersonalId<br />
                                                            <strong>Phone:</strong> @person.PhoneNumber<br />
                                                            <strong>Class:</strong> <span class="badge bg-light text-dark">@person.FlightType</span>
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-searchEmail="@ViewBag.SearchEmail">Previous</a>
                    </li>

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchEmail="@ViewBag.SearchEmail">@i</a>
                        </li>
                    }

                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-searchEmail="@ViewBag.SearchEmail">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>